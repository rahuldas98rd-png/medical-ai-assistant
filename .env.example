# =========================================================================
# MediMind AI — environment configuration
# Copy this file to `.env` and fill in values.
# DO NOT commit `.env` (it's in .gitignore).
# =========================================================================

# --- App settings ---
APP_NAME=MediMind AI
APP_ENV=development           # development | staging | production
DEBUG=true
LOG_LEVEL=INFO                # DEBUG | INFO | WARNING | ERROR

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:8501,http://localhost:3000

# --- Database ---
# Dev: SQLite (no setup needed)
DATABASE_URL=sqlite:///./data/medimind.db
# Prod: Supabase (free tier)
# DATABASE_URL=postgresql+psycopg2://USER:PASS@HOST:5432/postgres

# --- Model storage ---
MODELS_DIR=./data/models

# --- Hugging Face (free) ---
# Get from https://huggingface.co/settings/tokens (free account)
# Required for Phase 3+ (downloading large models, calling inference API)
HUGGINGFACE_TOKEN=

# --- Ollama (local LLM, free, optional) ---
# Set if running Ollama locally for the chat module
# Install: https://ollama.com/download
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=phi3:mini

# --- Frontend ---
BACKEND_API_URL=http://localhost:8000/api/v1
